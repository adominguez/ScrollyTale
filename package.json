{
  "name": "scrollytale",
  "version": "0.1.0",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "type": "module",
  "description": "Motor de scrollytelling reutilizable para Astro: fondo fijo con crossfade/slide entre escenas + reveal de texto al hacer scroll.",
  "exports": {
    "./ScrollyStage.astro": "./src/ScrollyStage.astro",
    "./ScrollySection.astro": "./src/ScrollySection.astro",
    "./ScrollyPinned.astro": "./src/ScrollyPinned.astro",
    "./scrollytelling.client.js": "./src/scrollytelling.client.js"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "astro": "^7.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "astro": "^7.0.6",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.10"
  }
}
