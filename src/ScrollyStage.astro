---
// ScrollyStage.astro
// Wrapper reutilizable para montar un scrollytelling tipo Shorthand en
// cualquier página. Se encarga de:
//   1. Pintar el fondo fijo a pantalla completa con crossfade entre escenas.
//   2. Envolver las <ScrollySection> que le pases como children.
//   3. Cargar el script cliente que decide qué fondo mostrar según qué
//      sección está más cerca del centro de la pantalla, y que revela
//      cada sección al entrar en el viewport.
//
// Uso:
//   <ScrollyStage backgrounds={backgrounds}>
//     <ScrollySection bg="hero">...</ScrollySection>
//     <ScrollySection bg="forest" align="left">...</ScrollySection>
//   </ScrollyStage>
//
// El listado de fondos vive centralizado (p.ej. src/content/backgrounds.json)
// y cada <ScrollySection bg="..."> solo referencia el id que le toca.
//
// scrollSync (opcional, default false): por defecto el fondo se anima una
// vez (cuando una sección pasa a ser la más cercana al centro) con una
// duración fija de CSS, sin importar si sigues scrolleando o paras en
// seco. Con scrollSync={true} el motor cliente calcula en cada frame el
// progreso real entre la sección anterior y la siguiente a partir de la
// posición de scroll, y mueve/desvanece los fondos en proporción exacta
// — como un scrub atado al scroll, sin temporizador propio.
//
// imageMobile (opcional, por fondo): cada escena puede declarar una imagen
// alternativa para mobile, usando el mismo corte de 560px que el resto del
// proyecto. Se resuelve solo con CSS vía custom properties + media query,
// así que el motor cliente no necesita saber nada de esto. Si una escena
// no define imageMobile, sigue usando image también en mobile.
//
// type="video" (opcional, por fondo, default "image"): en vez de una imagen
// CSS, la capa es un <video> (muted/loop/playsinline, autoplay gestionado
// por el motor cliente vía play()/pause() — nunca con el atributo autoplay,
// para no reproducir de fondo escenas que aún no están activas). videoMobile
// es igual que imageMobile pero para vídeo: se resuelve con un <source
// media="(max-width: 560px)">, que el navegador solo reevalúa al cargar el
// recurso (no en cada resize en vivo, a diferencia del CSS var de
// imageMobile). poster es opcional y se muestra mientras el vídeo carga.
//
// Lazy-load de vídeo: solo el primer fondo (el que se ve desde el primer
// frame) lleva <source> en el HTML servido, así que el navegador empieza a
// descargarlo de inmediato. El resto de fondos de vídeo se sirven SIN
// <source> — solo con la URL guardada en data-video-src/data-video-mobile-
// src — y es el motor cliente quien crea el <source> y llama a video.load()
// cuando el usuario está a punto de llegar a la sección que los activa (ver
// scrollytelling.client.js). Así no se descargan de golpe todos los vídeos
// de una página al cargarla, solo los que el usuario realmente visita.

interface Background {
  id: string;
  type?: 'image' | 'video';
  image?: string;
  imageMobile?: string;
  video?: string;
  videoMobile?: string;
  poster?: string;
}

interface Props {
  backgrounds: Background[];
  scrollSync?: boolean;
}

const { backgrounds, scrollSync = false } = Astro.props;
---

<div class="scrolly-stage" id="scrollyStage" data-scroll-sync={scrollSync}>
  {backgrounds.map((bg, i) => (
    bg.type === 'video' ? (
      <video
        class="scrolly-bg scrolly-bg--video"
        class:list={[{ 'is-active': i === 0 }]}
        data-bg={bg.id}
        data-video-src={i === 0 ? undefined : bg.video}
        data-video-mobile-src={i === 0 ? undefined : bg.videoMobile}
        muted
        loop
        playsinline
        preload={i === 0 ? 'auto' : 'none'}
        poster={bg.poster}
      >
        {i === 0 && bg.videoMobile && <source src={bg.videoMobile} media="(max-width: 560px)" />}
        {i === 0 && <source src={bg.video} />}
      </video>
    ) : (
      <div
        class="scrolly-bg"
        class:list={[{ 'is-active': i === 0 }]}
        data-bg={bg.id}
        style={`--bg-image:url('${bg.image}');${bg.imageMobile ? `--bg-image-mobile:url('${bg.imageMobile}');` : ''}`}
      ></div>
    )
  ))}
  <div class="scrolly-overlay"></div>
</div>

<div class="scrolly-content">
  <slot />
</div>

<script src="./scrollytelling.client.js"></script>

<style>
  .scrolly-stage {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .scrolly-bg {
    position: absolute;
    inset: 0;
    background-image: var(--bg-image);
    background-size: cover;
    background-position: center;
    opacity: 0;
    visibility: hidden;
    z-index: 1;
    transition:
      opacity 1s ease-in-out,
      transform 0.9s var(--ease, cubic-bezier(0.22, 0.61, 0.36, 1)),
      visibility 0s;
  }
  /* Por debajo de 560px (mismo corte que el resto del proyecto) usamos la
     imagen de mobile si la escena la define; si no, --bg-image-mobile no
     existe y el fallback de var() deja la imagen de desktop tal cual. */
  @media (max-width: 560px) {
    .scrolly-bg {
      background-image: var(--bg-image-mobile, var(--bg-image));
    }
  }
  /* Capas de vídeo: mismas reglas de posición/transición que .scrolly-bg
     (heredadas de arriba), solo añadimos cómo rellena la caja, ya que un
     <video> no estira solo con inset:0 como sí hace un div. */
  .scrolly-bg--video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  /* La capa entrante (is-active) siempre queda por encima de la
     saliente (is-leaving) para que el slide la "tape" al avanzar. */
  .scrolly-bg.is-active {
    z-index: 2;
  }

  /* scrollSync: el motor cliente fija opacity/transform/z-index por JS en
     cada frame con valores inline, así que desactivamos la transición CSS
     para que el cambio sea instantáneo y siga al scroll 1:1, sin el
     retardo que metería una transición de 0.9-1s. Astro serializa la prop
     booleana como string ("true"/"false"), nunca omite el atributo, así
     que hay que comparar el valor exacto — [data-scroll-sync] a secas
     siempre haría match, también cuando vale "false". */
  .scrolly-stage[data-scroll-sync='true'] .scrolly-bg {
    transition: none;
  }

  /* ---- fade (default): solo opacidad, sin desplazamiento ---- */
  .scrolly-bg.is-active {
    opacity: 1;
    visibility: visible;
    transform: translate(0, 0);
  }

  /* ---- slide-horizontal: entra/sale en el eje X ----
     La dirección concreta (desde dónde entra) la decide el JS añadiendo
     data-enter-from="left|right" en el momento del cambio, según el
     sentido del scroll. */
  .scrolly-bg[data-transition='slide-horizontal'] {
    transform: translateX(0);
  }
  .scrolly-bg[data-transition='slide-horizontal']:not(.is-active)[data-enter-from='right'] {
    transform: translateX(100%);
  }
  .scrolly-bg[data-transition='slide-horizontal']:not(.is-active)[data-enter-from='left'] {
    transform: translateX(-100%);
  }
  .scrolly-bg[data-transition='slide-horizontal'].is-leaving[data-enter-from='right'] {
    transform: translateX(-100%);
  }
  .scrolly-bg[data-transition='slide-horizontal'].is-leaving[data-enter-from='left'] {
    transform: translateX(100%);
  }
  .scrolly-bg[data-transition='slide-horizontal'].is-active {
    transform: translateX(0);
  }

  /* ---- slide-vertical: igual que arriba pero en el eje Y ---- */
  .scrolly-bg[data-transition='slide-vertical']:not(.is-active)[data-enter-from='bottom'] {
    transform: translateY(100%);
  }
  .scrolly-bg[data-transition='slide-vertical']:not(.is-active)[data-enter-from='top'] {
    transform: translateY(-100%);
  }
  .scrolly-bg[data-transition='slide-vertical'].is-leaving[data-enter-from='bottom'] {
    transform: translateY(-100%);
  }
  .scrolly-bg[data-transition='slide-vertical'].is-leaving[data-enter-from='top'] {
    transform: translateY(100%);
  }
  .scrolly-bg[data-transition='slide-vertical'].is-active {
    transform: translateY(0);
  }

  /* ---- fade-visibility: la entrante escala de 1.15 a 1 mientras hace fade-in;
     la saliente solo se desvanece (fade-out), sin escalar. No depende de
     la dirección del scroll, por eso no usa [data-enter-from]. ---- */
  .scrolly-bg[data-transition='fade-visibility']:not(.is-active) {
    opacity: 0;
    transform: scale(1.15);
  }
  .scrolly-bg[data-transition='fade-visibility'].is-leaving {
    opacity: 0;
    transform: scale(1);
  }
  .scrolly-bg[data-transition='fade-visibility'].is-active {
    opacity: 1;
    transform: scale(1);
  }

  /* ---- zoom-in: la entrante escala desde (1 - --bg-zoom-scale) hasta 1
     mientras hace fade-in, dando sensación de acercarse a la imagen; la
     saliente solo se desvanece (fade-out), sin escalar. --bg-zoom-scale lo
     fija el JS por capa a partir de la prop bgZoomScale de la sección
     (fallback 0.15 si no llega). Simétrico, no depende de la dirección
     del scroll. ---- */
  .scrolly-bg[data-transition='zoom-in']:not(.is-active) {
    opacity: 0;
    transform: scale(calc(1 - var(--bg-zoom-scale, 0.15)));
  }
  .scrolly-bg[data-transition='zoom-in'].is-leaving {
    opacity: 0;
    transform: scale(1);
  }
  .scrolly-bg[data-transition='zoom-in'].is-active {
    opacity: 1;
    transform: scale(1);
  }

  /* ---- zoom-out: igual que zoom-in pero la entrante escala desde
     (1 + --bg-zoom-scale) hasta 1, dando sensación de alejarse. ---- */
  .scrolly-bg[data-transition='zoom-out']:not(.is-active) {
    opacity: 0;
    transform: scale(calc(1 + var(--bg-zoom-scale, 0.15)));
  }
  .scrolly-bg[data-transition='zoom-out'].is-leaving {
    opacity: 0;
    transform: scale(1);
  }
  .scrolly-bg[data-transition='zoom-out'].is-active {
    opacity: 1;
    transform: scale(1);
  }

  /* Las capas con slide, fade o zoom se ven en cuanto empiezan a
     entrar/salir, no solo al terminar la transición (a diferencia del
     fade puro, que solo usa opacity). Los estados concretos de opacidad
     definidos arriba tienen más especificidad y prevalecen sobre este
     forzado. */
  .scrolly-bg[data-transition^='slide'],
  .scrolly-bg[data-transition^='fade'],
  .scrolly-bg[data-transition^='zoom'] {
    opacity: 1;
    visibility: visible;
  }

  .scrolly-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 8, 6, 0.35) 0%,
      rgba(10, 8, 6, 0.55) 100%
    );
    pointer-events: none;
    z-index: 5;
  }
  .scrolly-content {
    position: relative;
    z-index: 10;
  }
</style>
