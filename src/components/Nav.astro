---
interface Props {
  brand?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const { brand = 'PawTales', ctaLabel = 'Conoce a los Paws', ctaHref = '#cierre' } = Astro.props;
---

<div class="thread-rail" aria-hidden="true"><div class="thread-fill" id="threadFill"></div></div>

<nav class="nav">
  <span class="nav-mark">{brand}</span>
  <a class="nav-cta" href={ctaHref}>{ctaLabel}</a>
</nav>

<style>
  .thread-rail {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: rgba(255, 255, 255, 0.08);
    z-index: 300;
  }
  .thread-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--amber), #c25b3f);
    transition: width 0.08s linear;
  }
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 250;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px clamp(20px, 5vw, 56px) 0;
  }
  .nav-mark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--cream);
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.4);
  }
  .nav-cta {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.85rem;
    background: var(--amber);
    color: var(--ink);
    padding: 9px 18px;
    border-radius: 999px;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.3);
    transition: transform 0.25s var(--ease);
  }
  .nav-cta:hover {
    transform: translateY(-2px);
  }
</style>
