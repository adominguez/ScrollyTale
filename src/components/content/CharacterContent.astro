---
// CharacterContent.astro
// Contenido "listo para usar" para presentar un personaje. Se coloca
// dentro de un <ScrollySection bg="..." align="left|right">.

interface Props {
  name?: string;
  trait?: string;
  line?: string;
  quote?: string;
  color?: string;
  image?: string;
  imageAlt?: string;
}

const {
  name,
  trait,
  line,
  quote,
  color = '#E8A547',
  image,
  imageAlt = '',
} = Astro.props;
---

{image && <img class="char-img" src={image} alt={imageAlt} />}
{name && <p class="char-name" style={`color:${color}`}>{name}</p>}
{trait && <h4 class="char-trait">{trait}</h4>}
{line && <p class="char-line">{line}</p>}
{quote && <p class="char-quote">{quote}</p>}

<style>
  .char-img {
    width: clamp(160px, 22vw, 260px);
    height: auto;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.5));
    margin-bottom: 24px;
    display: block;
  }
  /* El alineado izq/der lo decide ScrollySection en .scrolly-inner;
     aquí solo seguimos su alineación para centrar/alinear la imagen. */
  :global(.scrolly-inner--right) .char-img {
    margin-left: auto;
  }
  :global(.scrolly-inner--left) .char-img {
    margin-right: auto;
  }
  .char-name {
    font-family: var(--font-script);
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    margin-bottom: 6px;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
  }
  .char-trait {
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.85rem;
    color: rgba(250, 245, 236, 0.65);
    margin-bottom: 18px;
  }
  .char-line {
    font-size: clamp(1.05rem, 1.8vw, 1.3rem);
    line-height: 1.6;
    color: rgba(250, 245, 236, 0.92);
    margin-bottom: 18px;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.35);
  }
  .char-quote {
    font-family: var(--font-script);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    color: var(--amber);
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.4);
  }

  @media (max-width: 900px) {
    :global(.scrolly-inner--right) .char-img,
    :global(.scrolly-inner--left) .char-img {
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
