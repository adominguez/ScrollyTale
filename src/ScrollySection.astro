---
// ScrollySection.astro
// Una "diapositiva" del scrollytelling. Pone la mecánica (altura mínima,
// qué fondo activar, alineación del texto, reveal on-scroll) y deja el
// contenido completamente libre a través del slot por defecto: puedes
// meter uno de los componentes "listos para usar" (HeroContent,
// CharacterContent, UnboxContent, ClosingContent) o tu propio HTML.
//
// Props:
//   bg             — id del fondo a activar (debe existir en backgrounds.json)
//   align          — "left" | "right" | "center" (alineación del bloque de texto)
//   minH           — alto mínimo de la sección (admite cualquier valor CSS, ej. "120vh")
//   width          — max-width del .scrolly-inner (admite cualquier valor CSS,
//                    ej. "800px", "60ch"). Si no se indica, usa el valor por
//                    defecto (560px, o 680px con align="center").
//   id             — id HTML opcional, útil para anclas (ej. id="cierre")
//   bgTransition   — cómo entra el FONDO al activarse esta sección:
//                       "fade"             (default) — solo opacidad
//                       "slide-horizontal" — entra/sale en el eje X;
//                                            el sentido (izq/der) lo decide
//                                            automáticamente la dirección
//                                            de scroll, no esta prop
//                       "slide-vertical"   — igual que arriba, en el eje Y
//                       "fade-visibility"          — entra escalando de 1.15 a 1
//                                            con fade; simétrico, no
//                                            depende de la dirección del
//                                            scroll
//                       "zoom-in"          — entra escalando desde
//                                            (1 - bgZoomScale) hasta 1 con
//                                            fade (se "acerca")
//                       "zoom-out"         — entra escalando desde
//                                            (1 + bgZoomScale) hasta 1 con
//                                            fade (se "aleja")
//   bgZoomScale    — cuánto se nota el efecto de "zoom-in"/"zoom-out" (0..1,
//                    como fracción de la escala normal). Sin efecto en el
//                    resto de bgTransition.
//   contentTransition — cómo se mueve el CONTENIDO (scrolly-inner) al
//                    cambiar entre secciones que comparten el mismo fondo:
//                       "slide-horizontal" — el bloque de texto sale hacia
//                                            la izquierda/derecha (según la
//                                            dirección del scroll) y entra
//                                            el de la sección siguiente
//                                            desde el lado contrario. Las
//                                            secciones con este valor quedan
//                                            fuera del IntersectionObserver
//                                            (el motor JS gestiona su estado
//                                            directamente). Compatible con
//                                            scrollSync.
//   textTransition — cómo aparece el bloque de TEXTO de esta sección al
//                    entrar en el viewport:
//                       "fade-up"    (default) — fade + sube desde abajo
//                       "fade-down"  — fade + baja desde arriba
//                       "slide-left" — fade + entra desde la izquierda
//                       "slide-right"— fade + entra desde la derecha
//                       "zoom-in"    — fade + escala desde 0.92 a 1

interface Props {
  bg: string;
  align?: 'left' | 'right' | 'center';
  minH?: string;
  width?: string;
  id?: string;
  bgTransition?: 'fade' | 'slide-horizontal' | 'slide-vertical' | 'fade-visibility' | 'zoom-in' | 'zoom-out';
  bgZoomScale?: number;
  contentTransition?: 'slide-horizontal';
  contentThreshold?: number;
  textTransition?: 'fade-up' | 'fade-down' | 'slide-left' | 'slide-right' | 'zoom-in';
}

const {
  bg,
  align = 'center',
  minH = '100vh',
  width,
  id,
  bgTransition = 'fade',
  bgZoomScale = 0.15,
  contentTransition,
  contentThreshold = 0,
  textTransition = 'fade-up',
} = Astro.props;
---

<section
  class="scrolly-section"
  data-bg-target={bg}
  data-bg-transition={bgTransition}
  data-bg-zoom-scale={bgZoomScale}
  data-content-transition={contentTransition}
  data-content-threshold={contentTransition ? contentThreshold : undefined}
  id={id}
  style={`min-height:${minH}`}
>
  <div
    class={`scrolly-inner scrolly-inner--${align}`}
    data-text-transition={contentTransition ? undefined : textTransition}
    data-content-transition={contentTransition}
    style={width ? `max-width:${width}` : undefined}
  >
    <slot />
  </div>
</section>

<style>
  .scrolly-section {
    position: relative;
    display: flex;
    align-items: center;
    padding: 0 clamp(20px, 6vw, 70px);
  }
  .scrolly-inner {
    max-width: 560px;
    opacity: 0;
    transition:
      opacity 0.7s var(--ease, cubic-bezier(0.22, 0.61, 0.36, 1)),
      transform 0.7s var(--ease, cubic-bezier(0.22, 0.61, 0.36, 1));
  }
  .scrolly-inner.in-view {
    opacity: 1;
    transform: translate(0, 0) scale(1);
  }
  .scrolly-inner--center {
    margin: 0 auto;
    text-align: center;
    max-width: 680px;
  }
  .scrolly-inner--left {
    margin-right: auto;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .scrolly-inner--right {
    margin-left: auto;
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  /* ---- variantes de textTransition: solo definen el estado de PARTIDA
     (antes de in-view); el estado final siempre es opacity:1 / transform:none,
     ya cubierto por .scrolly-inner.in-view arriba. ---- */
  .scrolly-inner[data-text-transition='fade-up'] {
    transform: translateY(28px);
  }
  .scrolly-inner[data-text-transition='fade-down'] {
    transform: translateY(-28px);
  }
  .scrolly-inner[data-text-transition='slide-left'] {
    transform: translateX(-50px);
  }
  .scrolly-inner[data-text-transition='slide-right'] {
    transform: translateX(50px);
  }
  .scrolly-inner[data-text-transition='zoom-in'] {
    transform: scale(0.92);
  }

  /* ---- contentTransition="slide-horizontal" ----
     El inner se saca del flujo del documento (position:fixed) y se ancla
     al viewport igual que el fondo. Así no scrollea verticalmente y el
     slide horizontal cubre la pantalla entera sin overflow ni z-index
     externos. La <section> queda como spacer invisible para que el JS
     detecte qué sección está centrada en el viewport. ---- */

  .scrolly-inner[data-content-transition='slide-horizontal'] {
    position: fixed;
    top: 50%;
    z-index: 20;
    opacity: 1;
    /* default: fuera de pantalla a la derecha + centrado verticalmente */
    transform: translate(100vw, -50%);
  }

  /* Ajuste horizontal según alineación (left/right usan posición absoluta;
     center usa left:0 right:0 + margin:auto que ya viene de --center). */
  .scrolly-inner--center[data-content-transition='slide-horizontal'] {
    left: 0;
    right: 0;
    padding: 0 clamp(20px, 6vw, 70px);
    box-sizing: border-box;
  }
  .scrolly-inner--left[data-content-transition='slide-horizontal'] {
    left: clamp(20px, 6vw, 70px);
    right: auto;
  }
  .scrolly-inner--right[data-content-transition='slide-horizontal'] {
    right: clamp(20px, 6vw, 70px);
    left: auto;
  }

  /* Espera fuera de pantalla según de qué lado entrará. */
  .scrolly-inner[data-content-transition='slide-horizontal']:not(.is-active)[data-content-enter-from='right'] {
    transform: translate(100vw, -50%);
  }
  .scrolly-inner[data-content-transition='slide-horizontal']:not(.is-active)[data-content-enter-from='left'] {
    transform: translate(-100vw, -50%);
  }

  /* Activo: en su posición natural, centrado verticalmente. */
  .scrolly-inner[data-content-transition='slide-horizontal'].is-active {
    transform: translate(0, -50%);
    opacity: 1;
  }

  /* Salida: lado opuesto al del entrante. */
  .scrolly-inner[data-content-transition='slide-horizontal'].is-leaving[data-content-enter-from='right'] {
    transform: translate(-100vw, -50%);
  }
  .scrolly-inner[data-content-transition='slide-horizontal'].is-leaving[data-content-enter-from='left'] {
    transform: translate(100vw, -50%);
  }

  @media (max-width: 900px) {
    .scrolly-inner--left,
    .scrolly-inner--right {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }
    /* Los inners fixed left/right también se centran en móvil. */
    .scrolly-inner--left[data-content-transition='slide-horizontal'],
    .scrolly-inner--right[data-content-transition='slide-horizontal'] {
      left: 0;
      right: 0;
      padding: 0 clamp(20px, 6vw, 70px);
      box-sizing: border-box;
    }
  }
  @media (max-width: 560px) {
    .scrolly-section {
      padding: 0 22px;
    }
  }
</style>
